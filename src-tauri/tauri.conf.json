{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "每日待办",
  "version": "1.0.0",
  "identifier": "com.dailytodo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "editor",
        "title": "每日待办 - 编辑",
        "width": 450,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "minWidth": 350,
        "minHeight": 450,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/32x32.png",
      "tooltip": "每日待办",
      "menuOnLeftClick": false
    }
  },
  "plugins": {}
}
